# =====================================================================
# Production env for docker-compose.prod.yml
# On your server:  cp .env.prod.example .env   (then fill the values)
# Generate secrets with:  openssl rand -hex 32
# =====================================================================

# ---- Infra credentials ----
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me_to_a_strong_password
REDIS_PASSWORD=change_me_to_a_strong_password

# ---- Shared app secrets (JWT_* and INTERNAL_SERVICE_KEY must be identical across services) ----
JWT_ACCESS_SECRET=change_me
JWT_REFRESH_SECRET=change_me
OTP_HMAC_SECRET=change_me
INTERNAL_SERVICE_KEY=change_me

# ---- Email (Gmail SMTP) — Google Account > Security > App passwords ----
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password
MAIL_FROM=IRCTC <you@gmail.com>

# ---- Google OAuth ----
GOOGLE_CLIENT_ID=your_google_client_id

# ---- Razorpay (test or live keys) ----
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ---- Public origin allowed by CORS (your VM IP or domain, where the frontend is served) ----
PUBLIC_ORIGIN=http://localhost
